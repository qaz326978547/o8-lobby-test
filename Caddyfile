# Caddyfile for o8-lobby-test

:80 {
    encode gzip zstd

    # /api/* 反向代理到真實 API（handle 為互斥區塊，依序比對，
    # 不受 Caddy 內建 try_files 排在 reverse_proxy 之前的固定順序影響）
    handle /api/* {
        reverse_proxy https://frontendwebsite.ugsdev.com {
            header_up Host frontendwebsite.ugsdev.com
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # 其餘路徑：靜態檔案 + SPA fallback
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }

    log {
        output stdout
        format json
    }
}
